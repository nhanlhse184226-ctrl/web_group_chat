@page
@model IndexModel
@{
    ViewData["Title"] = "Group Chat";
}

<div class="chat-shell">
    <section class="chat-panel" aria-label="Group chat">
        <header class="chat-header">
            <div>
                <h1>Group Chat</h1>
                <p><span id="connectionStatus" class="connection-pill">Connecting...</span></p>
            </div>
            <form id="nameForm" class="name-form">
                <input id="usernameInput" class="chat-input" maxlength="24" placeholder="Username" autocomplete="nickname" />
                <button class="primary-button" type="submit">Set Name</button>
            </form>
        </header>

        <div id="messagesList" class="messages-list" aria-live="polite"></div>

        <div class="quick-actions" aria-label="Quick reactions">
            <button type="button" class="emoji-button" data-emoji="&#128514;">&#128514;</button>
            <button type="button" class="emoji-button" data-emoji="&#128557;">&#128557;</button>
            <button type="button" class="emoji-button" data-emoji="&#128293;">&#128293;</button>
            <button type="button" class="emoji-button" data-emoji="&#10084;&#65039;">&#10084;&#65039;</button>
            <button type="button" class="emoji-button" data-emoji="&#128077;">&#128077;</button>
            <button type="button" class="sticker-button" data-sticker="frog">
                <img src="~/stickers/frog.png" alt="Frog sticker" />
            </button>
            <button type="button" class="sticker-button" data-sticker="cute">
                <img src="~/stickers/cute.png" alt="Cute sticker" />
            </button>
            <button type="button" class="sticker-button" data-sticker="heart">
                <img src="~/stickers/heart.png" alt="Heart sticker" />
            </button>
        </div>

        <form id="messageForm" class="composer">
            <input id="messageInput" class="chat-input" placeholder="Type a message..." autocomplete="off" />
            <label class="file-button" for="fileInput">File</label>
            <input id="fileInput" name="chatFile" type="file" hidden />
            <button class="primary-button" type="submit">Send</button>
        </form>
        <div id="typingIndicator" class="typing-indicator" aria-live="polite"></div>
        <div id="uploadStatus" class="upload-status"></div>
    </section>

    <aside class="users-panel" aria-label="Online users">
        <div class="users-heading">
            <h2>Online</h2>
            <span id="onlineCount">0</span>
        </div>
        <ul id="usersList"></ul>
    </aside>
</div>

<form id="antiForgeryForm" method="post">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    <script src="~/lib/signalr/signalr.min.js"></script>
    <script src="~/js/chat.js" asp-append-version="true"></script>
}
