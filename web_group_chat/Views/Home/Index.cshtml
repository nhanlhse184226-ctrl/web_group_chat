@{
    ViewData["Title"] = "Group Chat";
}

<div class="chat-shell">
    <section class="chat-panel" aria-label="Group chat">
        <header class="chat-header">
            <div>
                <h1>Group Chat</h1>
                <p><span id="connectionStatus" class="connection-pill">Connecting...</span></p>
            </div>
            <form id="nameForm" class="name-form">
                <input id="usernameInput" class="chat-input" maxlength="24" placeholder="Username" autocomplete="nickname" />
                <button class="primary-button" type="submit">Set Name</button>
            </form>
        </header>

        <div id="messagesList" class="messages-list" aria-live="polite"></div>

        <div id="typingIndicator" class="typing-indicator" aria-live="polite"></div>

        <div id="attachPreview" class="attach-preview" hidden></div>

        <form id="messageForm" class="composer">
            <div class="composer-tools">
                <button type="button" id="emojiButton" class="icon-button" aria-label="Insert emoji" aria-haspopup="true" aria-expanded="false">&#128522;</button>
                <button type="button" id="stickerButton" class="icon-button sticker-toggle" aria-label="Open stickers" aria-haspopup="true" aria-expanded="false">
                    <img src="~/stickers/happy.svg" alt="" aria-hidden="true" />
                </button>
                <label class="icon-button" for="attachInput" aria-label="Attach file or image" title="Attach file or image">&#128206;</label>
                <input id="attachInput" type="file"
                       accept="image/jpeg,image/png,image/gif,image/webp,.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,.zip,.rar"
                       hidden />
            </div>
            <input id="messageInput" class="chat-input" placeholder="Type a message..." autocomplete="off" />
            <button class="primary-button" type="submit">Send</button>

            <div id="emojiPicker" class="emoji-picker" role="menu" aria-label="Emoji picker">
                <button type="button" class="emoji-option" role="menuitem">&#128512;</button>
                <button type="button" class="emoji-option" role="menuitem">&#128518;</button>
                <button type="button" class="emoji-option" role="menuitem">&#128514;</button>
                <button type="button" class="emoji-option" role="menuitem">&#128522;</button>
                <button type="button" class="emoji-option" role="menuitem">&#128525;</button>
                <button type="button" class="emoji-option" role="menuitem">&#128526;</button>
                <button type="button" class="emoji-option" role="menuitem">&#128546;</button>
                <button type="button" class="emoji-option" role="menuitem">&#128545;</button>
                <button type="button" class="emoji-option" role="menuitem">&#128077;</button>
                <button type="button" class="emoji-option" role="menuitem">&#128078;</button>
                <button type="button" class="emoji-option" role="menuitem">&#10084;&#65039;</button>
                <button type="button" class="emoji-option" role="menuitem">&#128293;</button>
                <button type="button" class="emoji-option" role="menuitem">&#127881;</button>
                <button type="button" class="emoji-option" role="menuitem">&#128591;</button>
            </div>

            <div id="stickerPicker" class="sticker-picker" role="menu" aria-label="Sticker picker"></div>
        </form>
    </section>

    <aside class="users-panel" aria-label="Online users">
        <div class="users-heading">
            <h2>Online</h2>
            <span id="onlineCount">0</span>
        </div>
        <ul id="usersList"></ul>
    </aside>
</div>

<div id="lightbox" class="lightbox" hidden>
    <img id="lightboxImage" class="lightbox-image" alt="Image preview" />
</div>

@section Scripts {
    <script src="~/lib/signalr/signalr.min.js"></script>
    <script src="~/js/chat.js" asp-append-version="true"></script>
}
